# ── LLM Providers ─────────────────────────────────────────────
# Configure UMA ou mais API keys. O sistema detecta automaticamente
# quais estão disponíveis. Prioridade: Groq > OpenAI > Anthropic > Google > Ollama

# Groq (GRATUITO — recomendado pra começar)
# Pegue sua key em: https://console.groq.com/keys
## ── Providers LLM (configure pelo menos um) ──────────────────

# Groq (GRATUITO) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# OpenAI (pago) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (pago) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (free tier) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-1.5-flash

# OpenAI (pago)
# Pegue sua key em: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (pago)
# Pegue sua key em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (free tier disponível)
# Pegue sua key em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash

# Ollama (local, gratuito — requer Ollama instalado)
# Instale em: https://ollama.com
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
